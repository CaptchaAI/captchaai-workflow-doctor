# Copy to .env (gitignored) and fill in real values.

# CaptchaAI 2captcha-compatible API key.
CAPTCHAAI_API_KEY=

# Optional: override default endpoints.
CAPTCHAAI_SUBMIT_ENDPOINT=https://ocr.captchaai.com/in.php
CAPTCHAAI_RESULT_ENDPOINT=https://ocr.captchaai.com/res.php

# Server target for real E2E runs (set on the server, not locally).
DOCTOR_TEST_SERVER_HOST=
DOCTOR_TEST_SERVER_USER=doctor

# Hard gate: must be set to "1" to allow real CaptchaAI API calls. Default off.
DOCTOR_ALLOW_REAL_API=0

# Demo credentials used by sample profiles (local mock only).
QA_EMAIL=demo@example.com
QA_PASSWORD=demo-password
